<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<!--
    Register screen.

    Note: The role selector has been removed per BTL requirement. Every new
    account is registered as MEMBER. The server side also enforces this.
-->
<VBox alignment="CENTER" prefHeight="600.0" prefWidth="450.0"
      spacing="12" styleClass="login-root"
      stylesheets="@../css/login.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.client.controller.RegisterController">

    <padding>
        <Insets bottom="32" left="40" right="40" top="32"/>
    </padding>

    <Label styleClass="title-label" text="ĐĂNG KÝ TÀI KHOẢN"/>
    <Label styleClass="subtitle-label" text="Tài khoản mới sẽ được tạo với vai trò Thành viên (MEMBER)."/>

    <VBox spacing="4">
        <Label text="Tên đăng nhập"/>
        <TextField fx:id="usernameField" styleClass="input-field"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Họ tên"/>
        <TextField fx:id="fullNameField" styleClass="input-field"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Email"/>
        <TextField fx:id="emailField" styleClass="input-field"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Mật khẩu"/>
        <PasswordField fx:id="passwordField" styleClass="input-field"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Xác nhận mật khẩu"/>
        <PasswordField fx:id="confirmField" styleClass="input-field"/>
    </VBox>

    <Button fx:id="registerBtn" maxWidth="Infinity" onAction="#handleRegister"
            styleClass="primary-btn" text="Đăng ký"/>

    <Button fx:id="backBtn" onAction="#handleBack" styleClass="link-btn"
            text="Quay lại đăng nhập"/>

    <Label fx:id="statusLabel" styleClass="status-label" text=""/>
</VBox>
