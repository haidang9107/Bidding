<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="900.0"
            styleClass="list-root"
            stylesheets="@../css/auction-list.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.client.controller.AuctionListController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="topbar">
            <padding><Insets bottom="14" left="20" right="20" top="14"/></padding>
            <Label styleClass="title-label" text="DANH SÁCH PHIÊN ĐẤU GIÁ"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel" styleClass="user-label" text=""/>
            <Button fx:id="logoutBtn" onAction="#handleLogout" styleClass="ghost-btn" text="Đăng xuất"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding><Insets bottom="20" left="20" right="20" top="14"/></padding>

            <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="auction-table">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="60" text="ID"/>
                    <TableColumn fx:id="colName" prefWidth="250" text="Sản phẩm"/>
                    <TableColumn fx:id="colCategory" prefWidth="130" text="Loại"/>
                    <TableColumn fx:id="colCurrentPrice" prefWidth="120" text="Giá hiện tại"/>
                    <TableColumn fx:id="colStatus" prefWidth="100" text="Trạng thái"/>
                    <TableColumn fx:id="colEndTime" prefWidth="180" text="Kết thúc"/>
                </columns>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button fx:id="refreshBtn" onAction="#handleRefresh" styleClass="secondary-btn" text="Làm mới"/>
                <Button fx:id="viewBtn" defaultButton="true" onAction="#handleView" styleClass="primary-btn" text="Xem phiên"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
