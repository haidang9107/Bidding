<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    Auction marketplace screen ("Sàn đấu giá trực tuyến").

    Layout (Tiki-inspired, minimal):
      - Top bar: title, search field, avatar (→ profile), logout button.
      - Left sidebar: category filter list.
      - Center: tabs for "Tất cả", "Đang đấu giá của tôi", "Quan tâm",
        each showing a wrapped grid of ProductCard items.
-->
<BorderPane styleClass="list-root"
            stylesheets="@../css/auction-list.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.client.controller.AuctionListController">

    <!-- ============== TOP BAR ============== -->
    <top>
        <VBox styleClass="topbar">
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="topbar-inner">
                <padding><Insets bottom="12" left="24" right="24" top="12"/></padding>

                <Label styleClass="title-label" text="SÀN ĐẤU GIÁ"/>

                <TextField fx:id="searchField" promptText="Tìm sản phẩm..."
                           styleClass="search-field" HBox.hgrow="ALWAYS"/>

                <Region prefWidth="8"/>

                <Label fx:id="userLabel" styleClass="user-label" text=""/>

                <Button fx:id="homeBtn" onAction="#handleGoHome" styleClass="ghost-btn"
                        text="Trang chính"/>

                <Button onAction="#handleGoMyProducts" styleClass="ghost-btn"
                        text="Sản phẩm của tôi"/>

                <Button fx:id="notifBtn" onAction="#handleOpenNotifications"
                        styleClass="ghost-btn" text="🔔"/>

                <Button fx:id="avatarBtn" onAction="#handleOpenProfile"
                        styleClass="avatar-btn" text="?"/>

                <Button fx:id="logoutBtn" onAction="#handleLogout" styleClass="ghost-btn"
                        text="Đăng xuất"/>
            </HBox>
        </VBox>
    </top>

    <!-- ============== LEFT: CATEGORY SIDEBAR ============== -->
    <left>
        <VBox spacing="10" styleClass="sidebar" prefWidth="240" minWidth="220">
            <padding><Insets bottom="20" left="20" right="14" top="20"/></padding>
            <Label styleClass="sidebar-title" text="DANH MỤC"/>
            <!-- Each toggle is a button that the controller wires up. -->
            <VBox fx:id="categoryBox" spacing="4" styleClass="category-box"/>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox styleClass="tip-card" spacing="4">
                <padding><Insets bottom="12" left="12" right="12" top="12"/></padding>
                <Label styleClass="sidebar-title" text="MẸO"/>
                <Label styleClass="muted-label" text="Bấm vào ♡ để thêm sản phẩm vào danh sách quan tâm."/>
            </VBox>
        </VBox>
    </left>

    <!-- ============== CENTER: TABS WITH PRODUCT GRIDS ============== -->
    <center>
        <VBox spacing="12">
            <padding><Insets bottom="20" left="14" right="24" top="14"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="tabHintLabel" styleClass="section-title"
                       text="Tất cả phiên đấu giá"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="refreshBtn" onAction="#handleRefresh"
                        styleClass="ghost-btn" text="Làm mới"/>
            </HBox>

            <TabPane fx:id="tabPane" styleClass="auction-tabs" tabClosingPolicy="UNAVAILABLE"
                     VBox.vgrow="ALWAYS">

                <Tab text="Tất cả">
                    <ScrollPane fitToWidth="true" styleClass="grid-scroll">
                        <FlowPane fx:id="allFlowPane" hgap="14" vgap="14"
                                  styleClass="product-grid">
                            <padding><Insets bottom="14" left="14" right="14" top="14"/></padding>
                        </FlowPane>
                    </ScrollPane>
                </Tab>

                <Tab text="Đang đấu giá của tôi">
                    <ScrollPane fitToWidth="true" styleClass="grid-scroll">
                        <VBox spacing="10">
                            <padding><Insets bottom="14" left="14" right="14" top="14"/></padding>
                            <Label fx:id="myBidsHint" styleClass="muted-label"
                                   text="Các sản phẩm bạn đã đặt giá sẽ xuất hiện ở đây."/>
                            <VBox fx:id="myBidsBox" spacing="10"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <Tab text="Quan tâm">
                    <ScrollPane fitToWidth="true" styleClass="grid-scroll">
                        <FlowPane fx:id="watchFlowPane" hgap="14" vgap="14"
                                  styleClass="product-grid">
                            <padding><Insets bottom="14" left="14" right="14" top="14"/></padding>
                        </FlowPane>
                    </ScrollPane>
                </Tab>
            </TabPane>

            <!-- Pagination controls for the "Tất cả" tab -->
            <HBox fx:id="paginationBar" alignment="CENTER" spacing="12"
                  styleClass="pagination-bar">
                <padding><Insets bottom="8" left="14" right="14" top="8"/></padding>
                <Button fx:id="firstPageBtn" onAction="#handleFirstPage"
                        styleClass="ghost-btn" text="« Đầu"/>
                <Button fx:id="prevPageBtn" onAction="#handlePrevPage"
                        styleClass="ghost-btn" text="‹ Trước"/>
                <Label fx:id="pageLabel" styleClass="user-label" text="Trang 1/1"/>
                <Button fx:id="nextPageBtn" onAction="#handleNextPage"
                        styleClass="ghost-btn" text="Sau ›"/>
                <Button fx:id="lastPageBtn" onAction="#handleLastPage"
                        styleClass="ghost-btn" text="Cuối »"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
