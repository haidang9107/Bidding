<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="800.0"
            styleClass="seller-root"
            stylesheets="@../css/seller-dashboard.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.client.controller.SellerDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="topbar">
            <padding><Insets bottom="14" left="20" right="20" top="14"/></padding>
            <Label styleClass="title-label" text="SELLER DASHBOARD"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel" styleClass="user-label" text=""/>
            <Button fx:id="viewAuctionsBtn" onAction="#handleViewAuctions" styleClass="ghost-btn" text="Xem các phiên"/>
            <Button fx:id="logoutBtn" onAction="#handleLogout" styleClass="ghost-btn" text="Đăng xuất"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="14">
            <padding><Insets bottom="20" left="40" right="40" top="20"/></padding>

            <VBox spacing="10" styleClass="card" maxWidth="640">
                <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>
                <Label styleClass="section-title" text="TẠO PHIÊN ĐẤU GIÁ MỚI"/>

                <GridPane hgap="12" vgap="10">
                    <Label styleClass="muted-label" text="Tên sản phẩm"
                           GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="nameField" styleClass="input-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label styleClass="muted-label" text="Mô tả"
                           GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextArea fx:id="descArea" prefRowCount="3" styleClass="input-field"
                              GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label styleClass="muted-label" text="Giá khởi điểm"
                           GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="startingPriceField" styleClass="input-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label styleClass="muted-label" text="Bước giá tối thiểu"
                           GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="bidIncrementField" styleClass="input-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label styleClass="muted-label" text="Thời lượng (phút)"
                           GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <TextField fx:id="durationField" styleClass="input-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label styleClass="muted-label" text="Loại sản phẩm"
                           GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <ChoiceBox fx:id="categoryBox" maxWidth="Infinity" styleClass="input-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                    <Label styleClass="muted-label" text="Hãng (Electronics/Vehicle)"
                           GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                    <TextField fx:id="brandField" styleClass="input-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                    <Label styleClass="muted-label" text="Bảo hành tháng (Electronics)"
                           GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                    <TextField fx:id="warrantyField" styleClass="input-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="7"/>

                    <Label styleClass="muted-label" text="Nghệ sĩ (Art)"
                           GridPane.columnIndex="0" GridPane.rowIndex="8"/>
                    <TextField fx:id="artistField" styleClass="input-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="8"/>

                    <Label styleClass="muted-label" text="Năm (Art/Vehicle)"
                           GridPane.columnIndex="0" GridPane.rowIndex="9"/>
                    <TextField fx:id="yearField" styleClass="input-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="9"/>

                    <Label styleClass="muted-label" text="Model (Vehicle)"
                           GridPane.columnIndex="0" GridPane.rowIndex="10"/>
                    <TextField fx:id="modelField" styleClass="input-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="10"/>
                </GridPane>

                <Button fx:id="createBtn" defaultButton="true" maxWidth="Infinity"
                        onAction="#handleCreate" styleClass="primary-btn" text="Tạo phiên"/>

                <Label fx:id="statusLabel" styleClass="status-label" text=""/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
