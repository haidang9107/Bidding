<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>

<HBox maxHeight="Infinity" maxWidth="Infinity" prefHeight="694.0" prefWidth="980.0" styleClass="root-container" stylesheets="@../css/create-account.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.client.network.CreateAccountController">

    <!-- ===== LEFT PANEL: Ảnh nền (chiếm 45% chiều rộng) ===== -->
    <StackPane maxHeight="Infinity" maxWidth="Infinity" styleClass="left-panel" HBox.hgrow="ALWAYS">

        <ImageView fx:id="bgImage" pickOnBounds="true" preserveRatio="false" StackPane.alignment="CENTER">
        </ImageView>

        <!-- Overlay tối nhẹ -->
        <Pane maxHeight="Infinity" maxWidth="Infinity" styleClass="left-overlay">
         <children>
      
              <!-- Logo AMU góc trên trái -->
              <VBox alignment="TOP_LEFT" layoutX="6.0" layoutY="13.0" maxHeight="Infinity" maxWidth="Infinity" prefHeight="122.0" prefWidth="619.0">
                  <padding>
                  <Insets bottom="0" left="28" right="28" top="28" />
               </padding>
                  <Label fx:id="tieuDe" styleClass="logo-label" text="Hệ thống đấu giá trực tuyến" />
              </VBox>
         </children></Pane>

    </StackPane>

    <!-- ===== RIGHT PANEL: Form (chiếm 55% chiều rộng) ===== -->
    <VBox alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" styleClass="right-panel" HBox.hgrow="ALWAYS">

        <!-- Form content được căn giữa theo chiều ngang -->
        <VBox alignment="CENTER_LEFT" maxWidth="460" VBox.vgrow="ALWAYS">

            <VBox.margin><Insets left="0" right="0" /></VBox.margin>

            <!-- Tiêu đề -->
            <Label styleClass="title-label" text="Tạo tài khoản" textFill="#0e183b">
                <VBox.margin><Insets bottom="32" /></VBox.margin>
            </Label>

            <!-- Họ + Tên -->
            <HBox spacing="14">
                <VBox.margin><Insets bottom="14" /></VBox.margin>
                <TextField fx:id="firstNameField" prefHeight="52" promptText="Tên" styleClass="text-field-dark" HBox.hgrow="ALWAYS" />
                <TextField fx:id="lastNameField" prefHeight="52" promptText="Họ" styleClass="text-field-dark" HBox.hgrow="ALWAYS" />
            </HBox>

            <!-- Email -->
            <TextField fx:id="emailField" maxWidth="Infinity" prefHeight="52" promptText="Email" styleClass="text-field-dark">
                <VBox.margin><Insets bottom="14" /></VBox.margin>
            </TextField>

            <!-- Mật khẩu -->
            <StackPane maxWidth="Infinity" prefHeight="52">
                <VBox.margin><Insets bottom="20" /></VBox.margin>
                <PasswordField fx:id="passwordField" maxWidth="Infinity" prefHeight="82.0" prefWidth="178.0" promptText="Nhập mật khẩu" styleClass="password-field-dark" />
                <Button fx:id="togglePasswordBtn" onAction="#handleTogglePassword" styleClass="toggle-password-btn" text="👁" StackPane.alignment="CENTER_RIGHT" />
            </StackPane>

            <!-- Checkbox điều khoản -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox.margin><Insets bottom="24" /></VBox.margin>
                <CheckBox fx:id="termsCheck" selected="true" styleClass="terms-check" />
                <HBox alignment="CENTER_LEFT" spacing="4">
                    <Label styleClass="terms-label" text="Tôi đồng ý với" />
                    <Hyperlink fx:id="termsLink" onAction="#handleTerms" styleClass="terms-link" text="Điều khoản dịch vụ" />
                </HBox>
            </HBox>

            <!-- Nút Tạo tài khoản -->
            <Button fx:id="createBtn" maxWidth="Infinity" onAction="#handleCreateAccount" prefHeight="52" styleClass="create-btn" text="Tạo tài khoản">
                <VBox.margin><Insets bottom="14" /></VBox.margin>
            </Button>

            <!-- Bạn đã có tài khoản? + Đăng nhập -->
            <HBox alignment="CENTER" maxWidth="Infinity" spacing="8">
                <VBox.margin><Insets bottom="22" /></VBox.margin>
                <Label styleClass="subtitle-label" text="Bạn đã có tài khoản?" />
                <Button fx:id="loginBtn" onAction="#handleLogin" styleClass="login-btn" text="Đăng nhập" />
            </HBox>

            <!-- Divider -->
            <HBox alignment="CENTER" maxWidth="Infinity" spacing="12">
                <VBox.margin><Insets bottom="22" /></VBox.margin>
                <Line endX="1" styleClass="divider-line" HBox.hgrow="ALWAYS" />
                <Label styleClass="divider-label" text="Hoặc đăng ký bằng" />
                <Line endX="1" styleClass="divider-line" HBox.hgrow="ALWAYS" />
            </HBox>

            <!-- Google + Apple -->
            <HBox maxWidth="Infinity" spacing="14">
                <Button fx:id="googleBtn" maxWidth="Infinity" onAction="#handleGoogle" prefHeight="50" styleClass="social-btn" HBox.hgrow="ALWAYS">
                    <graphic>
                        <HBox alignment="CENTER" spacing="10">
                            <Label styleClass="google-icon" text="G" />
                            <Label styleClass="social-label" text="Google" />
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="appleBtn" maxWidth="Infinity" onAction="#handleApple" prefHeight="50" styleClass="social-btn" HBox.hgrow="ALWAYS">
                    <graphic>
                        <HBox alignment="CENTER" spacing="10">
                            <Label styleClass="apple-icon" text="" />
                            <Label styleClass="social-label" text="Apple" />
                        </HBox>
                    </graphic>
                </Button>
            </HBox>

        </VBox>
    </VBox>

</HBox>
