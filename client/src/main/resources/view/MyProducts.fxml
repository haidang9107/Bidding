<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    "Sản phẩm của tôi" — kho cá nhân của user.

    Layout:
      - Topbar with title, user info, avatar, logout.
      - Center: 3 tabs
          * Trong kho       — products owned, not in auction → can be put up.
          * Đang đấu giá    — products currently in an active auction.
          * Đã bán / Lịch sử — products sold (left the kho).
      - Bottom-right: floating "+ Thêm sản phẩm" button.
-->
<BorderPane styleClass="myproducts-root"
            stylesheets="@../css/myproducts.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.client.controller.MyProductsController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="topbar">
            <padding><Insets bottom="14" left="20" right="20" top="14"/></padding>
            <Label styleClass="title-label" text="SẢN PHẨM CỦA TÔI"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel" styleClass="user-label" text=""/>
            <Button fx:id="backBtn" onAction="#handleBack" styleClass="ghost-btn" text="Trang chính"/>
            <Button fx:id="marketBtn" onAction="#handleGoMarket" styleClass="ghost-btn" text="Sàn đấu giá"/>
            <Button fx:id="logoutBtn" onAction="#handleLogout" styleClass="ghost-btn" text="Đăng xuất"/>
            <Button fx:id="avatarBtn" onAction="#handleOpenProfile" styleClass="avatar-btn" text="?"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding><Insets bottom="20" left="20" right="20" top="14"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="summaryLabel" styleClass="muted-label" text="Đang tải kho..."/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="refreshBtn" onAction="#handleRefresh" styleClass="ghost-btn" text="Làm mới"/>
                <Button fx:id="addBtn" onAction="#handleAddProduct" styleClass="success-btn"
                        text="+ Thêm sản phẩm"/>
            </HBox>

            <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" styleClass="myproducts-tabs"
                     VBox.vgrow="ALWAYS">
                <Tab text="Trong kho">
                    <ScrollPane fitToWidth="true" styleClass="grid-scroll">
                        <VBox fx:id="stockBox" spacing="10">
                            <padding><Insets bottom="14" left="14" right="14" top="14"/></padding>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <Tab text="Đang đấu giá">
                    <ScrollPane fitToWidth="true" styleClass="grid-scroll">
                        <VBox fx:id="auctionBox" spacing="10">
                            <padding><Insets bottom="14" left="14" right="14" top="14"/></padding>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <Tab text="Đã bán / Lịch sử">
                    <ScrollPane fitToWidth="true" styleClass="grid-scroll">
                        <VBox fx:id="soldBox" spacing="10">
                            <padding><Insets bottom="14" left="14" right="14" top="14"/></padding>
                        </VBox>
                    </ScrollPane>
                </Tab>
            </TabPane>
        </VBox>
    </center>
</BorderPane>
