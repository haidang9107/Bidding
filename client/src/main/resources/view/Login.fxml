<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="450.0"
      spacing="14" styleClass="login-root"
      stylesheets="@../css/login.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.LoginController">
    <padding>
        <Insets bottom="40" left="40" right="40" top="40"/>
    </padding>

    <Label styleClass="title-label" text="HỆ THỐNG ĐẤU GIÁ TRỰC TUYẾN"/>
    <Label styleClass="subtitle-label" text="Đăng nhập"/>

    <VBox spacing="4">
        <Label text="Tên đăng nhập"/>
        <TextField fx:id="usernameField" promptText="Nhập username" styleClass="input-field"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Mật khẩu"/>
        <PasswordField fx:id="passwordField" promptText="Nhập password" styleClass="input-field"/>
    </VBox>

    <Button fx:id="loginBtn" defaultButton="true" maxWidth="Infinity"
            onAction="#handleLogin" styleClass="primary-btn" text="Đăng nhập"/>

    <HBox alignment="CENTER" spacing="6">
        <Label text="Chưa có tài khoản?"/>
        <Button fx:id="registerBtn" onAction="#handleRegister"
                styleClass="link-btn" text="Đăng ký ngay"/>
    </HBox>

    <Label fx:id="statusLabel" styleClass="status-label" text=""/>
</VBox>
