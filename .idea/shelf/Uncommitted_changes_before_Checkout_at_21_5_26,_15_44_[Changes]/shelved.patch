+package org.example.server.repository;
+
+import org.example.model.Transaction;
+import java.sql.*;
+import java.util.ArrayList;
+import java.util.List;
+
+/**
+ * Data Access Object for unified transactions (Money + Asset ownership).
+ */
+public class TransactionDao {
+
+    public boolean insertTransaction(Connection connection, Transaction tx) throws SQLException {
+        String sql = """
+                INSERT INTO transactions (sender, receiver, type, product_id, amount, reference_id, description)
+                VALUES (?, ?, ?, ?, ?, ?, ?)
+                """;
+        try (PreparedStatement ps = connection.prepareStatement(sql, Statement.RETURN_GENERATED_KEYS)) {
+            ps.setString(1, tx.getSender());
+            ps.setString(2, tx.getReceiver());
+            ps.setInt(3, tx.getType());
+            if (tx.getProductId() != null) ps.setInt(4, tx.getProductId());
+            else ps.setNull(4, Types.INTEGER);
+            ps.setLong(5, tx.getAmount());
+            if (tx.getReferenceId() != null) ps.setInt(6, tx.getReferenceId());
+            else ps.setNull(6, Types.INTEGER);
+            ps.setString(7, tx.getDescription());
+
+            int affectedRows = ps.executeUpdate();
+            if (affectedRows > 0) {
+                try (ResultSet generatedKeys = ps.getGeneratedKeys()) {
+                    if (generatedKeys.next()) {
+                        tx.setTransactionId(generatedKeys.getInt(1));
+                    }
+                }
+                return true;
+            }
+        }
+        return false;
+    }
+
+    public List<Transaction> getHistoryByUser(Connection connection, String accountname) throws SQLException {
+        List<Transaction> list = new ArrayList<>();
+        String sql = "SELECT * FROM transactions WHERE sender = ? OR receiver = ? ORDER BY created_at DESC";
+        try (PreparedStatement ps = connection.prepareStatement(sql)) {
+            ps.setString(1, accountname);
+            ps.setString(2, accountname);
+            try (ResultSet rs = ps.executeQuery()) {
+                while (rs.next()) {
+                    list.add(mapResultSetToTransaction(rs));
+                }
+            }
+        }
+        return list;
+    }
+
+    private Transaction mapResultSetToTransaction(ResultSet rs) throws SQLException {
+        return new Transaction(
+                rs.getInt("transaction_id"),
+                rs.getString("sender"),
+                rs.getString("receiver"),
+                rs.getInt("type"),
+                (Integer) rs.getObject("product_id"),
+                rs.getLong("amount"),
+                (Integer) rs.getObject("reference_id"),
+                rs.getString("description"),
+                rs.getTimestamp("created_at")
+        );
+    }
+}
