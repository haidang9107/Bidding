# --- COMMON NETWORK CONFIG ---
# The host where the server is running (use localhost for local development)
SERVER_HOST=localhost
# Port for command requests (default: 8888)
SERVER_PORT=8888

# --- LOGGING CONFIG ---
# Set to true to enable console logging, false to disable
LOG_TO_CONSOLE=true

# --- DATABASE CONFIG ---
# Connection URL for MySQL (update host/port/database name as needed)
DB_URL=jdbc:mysql://localhost:3306/MySQL-DB?createDatabaseIfNotExist=true
# Database username
DB_USER=root
# Database password
DB_PASSWORD=root

# --- DOCKER CONFIG (Used by docker-compose) ---
# Database name for Docker MySQL container
MYSQL_DATABASE=MySQL-DB
# Root password for Docker MySQL container
MYSQL_ROOT_PASSWORD=root
# Port to expose MySQL on host machine
DB_PORT=3306

# --- ADVANCED PERFORMANCE & LOGIC CONFIG ---
DB_MAX_POOL_SIZE=10
SERVER_WORKER_THREADS=8
SERVER_QUEUE_CAPACITY=512
ANTI_SNIP_WINDOW_MS=60000
ANTI_SNIP_EXTENSION_MS=300000
